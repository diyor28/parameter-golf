set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

default:
  @just --list

run run_id='' extra_env='':
  ./pod_run.sh ./train_experiment_2x5090.env ./pod_experiment_2x5090.env "{{run_id}}" "{{extra_env}}"

smoke run_id='' extra_env='':
  ./pod_run.sh ./train_smoke_2x5090.env ./pod_experiment_2x5090.env "{{run_id}}" "{{extra_env}}"

record run_id='' extra_env='':
  ./pod_run.sh ./train_record_8xh100.env ./pod_record_8xh100.env "{{run_id}}" "{{extra_env}}"

status:
  ./pod_status.sh

ssh:
  resolved_pod_id=""; if [[ -f state/current_pod_id ]]; then resolved_pod_id="$(cat state/current_pod_id)"; fi; test -n "${resolved_pod_id}" || (echo "No current pod recorded in state/current_pod_id" >&2; exit 1); ssh_command="$(runpodctl ssh info "${resolved_pod_id}" -o json | ~/miniconda3/bin/python -c 'import json, sys; data = json.load(sys.stdin); cmd = data.get("ssh_command"); assert cmd, \"ssh_command not available; pod may not be ready\"; print(cmd)')"; \
  exec ${ssh_command}

stop:
  ./stop_pod.sh

delete:
  ./delete_pod.sh

summarize runs_dir="/workspace/parameter-golf/logs/record_runs":
  ~/miniconda3/bin/python ./summarize_runs.py "{{runs_dir}}"
