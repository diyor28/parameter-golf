# Main leaderboard-style baseline on 8 GPUs.
# This mirrors the repository baseline closely while staying reproducible.

GPU_COUNT=8
DOWNLOAD_VARIANT=sp1024
DOWNLOAD_TRAIN_SHARDS=80

RUN_ID=runpod_baseline_8gpu
VOCAB_SIZE=1024
NUM_LAYERS=9
MODEL_DIM=512
NUM_HEADS=8
NUM_KV_HEADS=4
MLP_MULT=2
TIE_EMBEDDINGS=1
TIED_EMBED_LR=0.05

MAX_WALLCLOCK_SECONDS=600
TRAIN_BATCH_TOKENS=524288
TRAIN_SEQ_LEN=1024
TRAIN_LOG_EVERY=50
VAL_LOSS_EVERY=200
