# Cheap validation run for a fresh Runpod pod.
# This keeps data download and training time small so you can verify the loop.

GPU_COUNT=1
DOWNLOAD_VARIANT=sp1024
DOWNLOAD_TRAIN_SHARDS=1

RUN_ID=runpod_smoke_1gpu
VOCAB_SIZE=1024
NUM_LAYERS=9
MODEL_DIM=512
NUM_HEADS=8
NUM_KV_HEADS=4
MLP_MULT=2
TIE_EMBEDDINGS=1

ITERATIONS=200
MAX_WALLCLOCK_SECONDS=120
TRAIN_BATCH_TOKENS=65536
TRAIN_SEQ_LEN=1024
TRAIN_LOG_EVERY=20
VAL_LOSS_EVERY=0
VAL_BATCH_SIZE=65536
